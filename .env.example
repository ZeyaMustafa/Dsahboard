# HDPOS Analytics - Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# --- Required in production ---
SECRET_KEY=change-me-to-a-long-random-string

# --- HTTPS flag (set to 1 when behind a TLS-terminating proxy) ---
HTTPS=0

# --- Development server ---
# FLASK_DEBUG=0
# HOST=127.0.0.1
# PORT=5000

# --- Data source ---
# SALES_CSV_PATH=data/random_supermarket_sales_1000.csv

# --- OAuth (leave blank to disable social login) ---
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# FACEBOOK_OAUTH_CLIENT_ID=
# FACEBOOK_OAUTH_CLIENT_SECRET=

# --- SQL Server connection ---
# SQL_SERVER_CONNECT_TIMEOUT=15
# SQL_SERVER_QUERY_TIMEOUT=60
# SQL_SERVER_DEFAULT_LOOKBACK_DAYS=90
# SQL_SERVER_FAILURE_COOLDOWN_SECONDS=60

# --- Cache TTLs (seconds) ---
# LIVE_SQL_CACHE_TTL_SECONDS=120
# AI_DECISION_CACHE_TTL_SECONDS=300

# --- Bundle analysis ---
# BUNDLE_SIGNAL_LOOKBACK_DAYS=15
